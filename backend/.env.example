# Email Configuration for Booking Notifications
# Copy this file to .env and fill in your email credentials

# SMTP Server Settings (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your Gmail address (sender)
SMTP_USER=your-email@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password-here

# Email address to receive booking notifications
RECIPIENT_EMAIL=neerupudijohnsonnj@gmail.com

# MongoDB Connection (optional)
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=godavari_captures
